# Compiled output — distributed via GitHub Releases, not committed to source
dist/
build/
*.spec

# Python cache
__pycache__/
*.pyc
*.pyo

# Virtual environments
.venv/
venv/
env/

# PyCharm project files
.idea/

# OS junk
.DS_Store
Thumbs.db

# Local deployment config — organisation-specific lab list and paths.
# Bundled into the built .exe but kept out of source control.
# See local_config.example.py for the template.
local_config.py

# One-shot credential file used during a release push (deleted after each run).
# Should never be present, but ignored as a safety net.
.gh_token
